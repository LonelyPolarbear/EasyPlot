// dllmain.cpp.in
#include <windows.h>
#include <iostream>

BOOL APIENTRY DllMain(HMODULE hmod, DWORD reason, LPVOID reserved) {
    switch (reason) {
    case DLL_PROCESS_ATTACH:
        std::cout << "DLL @DLL_NAME@ loaded" << std::endl;
        break;
    case DLL_PROCESS_DETACH:
        // cleanup if needed
        break;
    }
    return TRUE;
}